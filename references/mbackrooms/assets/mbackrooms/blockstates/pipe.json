{
  "multipart": [
    {
      "apply": {
        "model": "mbackrooms:block/pipe_middle"
      }
    },
    {
      "apply": {
        "model": "mbackrooms:block/pipe_connector"
      },
      "when": {
        "north": "true"
      }
    },
    {
      "apply": {
        "model": "mbackrooms:block/pipe_connector",
        "y": 90
      },
      "when": {
        "east": "true"
      }
    },
    {
      "apply": {
        "model": "mbackrooms:block/pipe_connector",
        "y": 180
      },
      "when": {
        "south": "true"
      }
    },
    {
      "apply": {
        "model": "mbackrooms:block/pipe_connector",
        "y": 270
      },
      "when": {
        "west": "true"
      }
    }
  ]
}